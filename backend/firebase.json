{
  "functions": {
    "source": ".",
    "codebase": "thinktwice-backend",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "*.local",
      "test/**"
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  },
  "auth": {
    "providers": {}
  }
}
