{
  "functions": {
    "source": ".",
    "codebase": "thinktwice-backend",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "*.local",
      "test/**"
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "My App",
        "supportEmail": "support@undefined.firebaseapp.com"
      }
    }
  }
}
